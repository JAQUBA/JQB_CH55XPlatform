{
    "name": "ch55x",
    "title": "JQB CH55x Platform",
    "description": "PlatformIO platform for WCH CH55x (CH551, CH552, CH554, CH559) MCS51 USB microcontrollers with ch55xduino Arduino-like framework and SDCC compiler",
    "homepage": "https://github.com/JAQUBA/JQB_CH55XPlatform",
    "license": "MIT",
    "keywords": [
        "ch552",
        "ch551",
        "ch554",
        "ch559",
        "ch55x",
        "mcs51",
        "8051",
        "wch",
        "usb",
        "sdcc",
        "ch55xduino",
        "platformio"
    ],
    "engines": {
        "platformio": ">=6.0.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/JAQUBA/JQB_CH55XPlatform.git"
    },
    "version": "1.0.0",
    "frameworks": {
        "arduino": {
            "package": "framework-ch55xduino",
            "script": "builder/frameworks/arduino.py"
        }
    },
    "packages": {
        "toolchain-sdcc-ch55x": {
            "type": "toolchain",
            "optional": false
        },
        "framework-ch55xduino": {
            "type": "framework",
            "optional": true
        },
        "tool-ch55xtools": {
            "type": "uploader",
            "optional": true
        }
    }
}
